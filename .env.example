# API URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Default administrative area fallback.
# Frontend ưu tiên mapView/boundary từ backend; các biến này dùng khi API chưa trả dữ liệu.
NEXT_PUBLIC_DEFAULT_WARD_ID=ngoc-to
NEXT_PUBLIC_DEFAULT_WARD_NAME=Ngọc Tố
NEXT_PUBLIC_DEFAULT_WARD_LABEL=Xã Ngọc Tố
NEXT_PUBLIC_DEFAULT_DISTRICT_NAME=Huyện Mỹ Xuyên
NEXT_PUBLIC_DEFAULT_PROVINCE_NAME=Thành phố Cần Thơ
NEXT_PUBLIC_DEFAULT_PROVINCE_SHORT=TP. Cần Thơ
NEXT_PUBLIC_DEFAULT_COUNTRY_NAME=Việt Nam
NEXT_PUBLIC_DEFAULT_MAP_CENTER=9.4466,105.9342
NEXT_PUBLIC_DEFAULT_MAP_ZOOM=15
NEXT_PUBLIC_DEFAULT_PAN_BOUNDS=105.45,9.35,106.15,10.45
NEXT_PUBLIC_STORAGE_NAMESPACE=ngoc-to

# Mapbox
# Get token at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Dashboard AI Assistant
# Browser chỉ gọi Next.js proxy route này, không chứa API key.
NEXT_PUBLIC_DASHBOARD_AI_ENDPOINT=/api/dashboard-ai

# Server-side only. Không dùng NEXT_PUBLIC cho OpenAI API key.
OPENAI_API_KEY=
# Optional
OPENAI_DASHBOARD_MODEL=gpt-4.1-mini
